# Gemini API Key
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# YouTube Data API v3 - OAuth 2.0 Client ID
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID (웹 애플리케이션)
# 승인된 JavaScript 원본: http://localhost:3100, https://japanese-mystery-ab75.vercel.app
# 승인된 리디렉션 URI: http://localhost:3100, https://japanese-mystery-ab75.vercel.app
VITE_YOUTUBE_CLIENT_ID=your_youtube_oauth_client_id_here
